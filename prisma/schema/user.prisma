model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  role          Role      @default(USER)
  permissions   String[]
  sessions      Session[]
  accounts      Account[]

  @@unique([email])
  @@map("user")
}

enum Role {
  ADMIN
  MANAGER
  USER
}